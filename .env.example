# boilerX environment variables
#
# Copy this file to `.env` (which is gitignored) and fill in real values.
# Never commit a real `.env`.

# ─────────────────────────────────────────────────────────────────────────────
# Capa 2 — LLM-backed Architect / Worker
# ─────────────────────────────────────────────────────────────────────────────

# Cursor SDK auth. Required for the LLM-backed Architect and Worker landing in
# Phase 3. Mint at: https://cursor.com/dashboard
# Both user keys and team service-account keys work.
CURSOR_API_KEY=

# Default model for the Cursor SDK. `composer-2` is the current production
# default; `auto` lets the server pick.
# CURSOR_MODEL=composer-2

# Optional: max USD a single `boiler evolve` run is allowed to spend on LLM
# calls. The orchestrator already enforces this via --max-cost-usd; this is the
# default applied when the flag is omitted.
# BOILERX_MAX_COST_USD=5.00

# Optional: override the per-model pricing table used to estimate cost per
# run (USD per 1M tokens). The Cursor SDK doesn't surface authoritative cost,
# so boilerX approximates from token counts. Reconcile with your dashboard
# for ground truth. Format: JSON; merges over DEFAULT_PRICING in
# packages/evolve/src/cost.ts. Example:
# BOILERX_PRICING='{"composer-2":{"inputPerMTokens":3.0,"outputPerMTokens":15.0}}'

# ─────────────────────────────────────────────────────────────────────────────
# Optional / informational
# ─────────────────────────────────────────────────────────────────────────────

# Log level for the CLI. Defaults to "info". Use "debug" while iterating.
# BOILERX_LOG_LEVEL=info
